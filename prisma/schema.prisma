// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id String @id @default(uuid())
  username String
  password String

  groups UsersGroups[]
}

model Groups {
  id String @id @default(uuid())
  name String
  todos Todos[]

  users UsersGroups[]
}

model Todos {
  id String @id @default(uuid())
  title String
  completed Boolean @default(false)
  dueTo DateTime @db.Date
  group Groups @relation(fields: [groupId], references: [id])
  groupId String 
}

model UsersGroups {
  userId String
  groupId String

  user Users @relation(fields: [userId], references: [id])
  group Groups @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}
